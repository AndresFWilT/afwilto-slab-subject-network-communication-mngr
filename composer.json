{
    "name": "afwilto/subject-network-communication-mngr",
    "type": "project",
    "description": "Network Communications II — Huffman and Shannon-Fano encoding algorithms microservice",
    "require": {
        "php": "^8.3",
        "laravel/framework": "^11.0"
    },
    "require-dev": {
        "pestphp/pest": "^2.0",
        "pestphp/pest-plugin-laravel": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "@php artisan test",
        "test:unit": "@php artisan test --testsuite=Unit",
        "test:feature": "@php artisan test --testsuite=Feature"
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
